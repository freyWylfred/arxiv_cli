# ========================================
# arXiv CLI 設定ファイル (config.ini.template)
# ========================================
# コピーして config.ini として使用してください
# ========================================

# --- 日付設定 ---
[DateRange]
today_only = false          # true: 今日の日付のみ処理（下記日付を無視）
start_date = 2024/01/01     # 検索開始日（YYYY/MM/DD）
end_date = 2024/01/01       # 検索終了日（YYYY/MM/DD）

# --- 検索設定 ---
[Search]
# クエリ例: all:"machine learning" OR all:"deep learning"
query = all:"model extraction" OR all:"prompt injection"
max_results = 100           # 最大取得件数（推奨: 100〜500）

# --- 出力設定 ---
[Files]
excel_file = arxiv_summaries.xlsx

# --- OpenAI設定（オプション） ---
[OpenAI]
use_openai = false          # 要約機能: true で有効化

# Azure OpenAI 接続情報
api_type = azure
endpoint = https://your-resource-name.openai.azure.com/
api_version = 2024-02-15-preview
deployment_name = gpt-4

# APIキー（環境変数 AZURE_OPENAI_API_KEY 推奨）
api_key = your-api-key-here
