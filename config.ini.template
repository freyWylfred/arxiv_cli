# ========================================
# arXiv 論文取得スクリプト 設定ファイル
# ========================================
# このファイルをコピーして "config.ini" として保存してください
#
# 使い方:
# 1. このファイルを "config.ini" にコピー
# 2. 以下の設定を編集
# 3. arxiv_cli.py を実行

[DateRange]
# 検索開始日（YYYY/MM/DD形式）
start_date = 2024/01/01

# 検索終了日（YYYY/MM/DD形式）
end_date = 2024/01/01

# 今日の論文だけを取得するモード（true/false）
today_only = false

[Search]
# 検索クエリ（arXiv API形式）
query = all:"model extraction" OR all:"prompt injection"

# 最大取得件数
max_results = 100

[Files]
# Excel出力ファイル名
excel_file = arxiv_summaries.xlsx

[OpenAI]
# OpenAI APIを使用して要約を生成するかどうか（true/false）
# デフォルト: false
use_openai = false
